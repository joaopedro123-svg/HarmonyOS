FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    binutils \
    git \
    python3 \
    python3-pip \
    ruby \
    shellcheck \
    curl \
    tree \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m harmony

RUN mkdir -p \
    /home/harmony/harmony_os/kernel/liteos_a \
    /home/harmony/harmony_os/kernel/liteos_m \
    /home/harmony/harmony_os/kernel/linux \
    /home/harmony/harmony_os/base/global \
    /home/harmony/harmony_os/base/hiviewdfx \
    /home/harmony/harmony_os/base/security \
    /home/harmony/harmony_os/base/startup \
    /home/harmony/harmony_os/foundation/aafwk \
    /home/harmony/harmony_os/foundation/ace \
    /home/harmony/harmony_os/foundation/appexecfwk \
    /home/harmony/harmony_os/foundation/communication \
    /home/harmony/harmony_os/applications \
    /home/harmony/harmony_os/device \
    /home/harmony/harmony_os/build \
    /home/harmony/harmony_os/drivers \
    /home/harmony/harmony_os/utils \
    /home/harmony/harmony_os/third_party \
    /home/harmony/harmony_os/vendor \
    /home/harmony/harmony_os/prebuilts \
    && chown -R harmony:harmony /home/harmony

USER harmony

WORKDIR /home/harmony

COPY --chown=harmony:harmony . .

RUN chmod +x scripts/*.sh

ENTRYPOINT ["/bin/bash", "-c", "bash scripts/demo.sh; exec /bin/bash"]
